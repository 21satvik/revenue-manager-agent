# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Postgres connection. Local docker-compose / cluster default:
DATABASE_URL=postgresql://hackathon:hackathon@localhost:5432/hotel_hackathon

# Anthropic API key for the agent (set in the deploy environment, never in git).
ANTHROPIC_API_KEY=sk-ant-...

# Model id (provider:model). Swappable; Claude by default.
MODEL_ID=anthropic:claude-sonnet-4-6

# HTTP basic auth for the deployed app. Send these via private intake, not the repo.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me
